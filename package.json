{
  "name": "fingerprint-chromium-engine",
  "version": "0.2.0-dev.20260515131908",
  "type": "module",
  "license": "MIT",
  "description": "Native Chromium anti-detect engine for Playwright with real-device fingerprint injection, proxy synchronization and persistent browser profiles.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "prepublishOnly": "npm run build",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/maxlogvn/PrivateChromiumEngine.git"
  },
  "keywords": [
    "chromium",
    "playwright",
    "automation",
    "anti-detect",
    "fingerprint",
    "browser",
    "stealth",
    "proxy",
    "webrtc",
    "webgl"
  ],
  "files": [
    "dist",
    "project.xml",
    "README.md"
  ],
  "os": [
    "win32"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "test": "mocha --exit",
    "clean": "rm -rf dist",
    "build": "npm run clean && tsup",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "playwright-core": ">=1.60.0"
  },
  "peerDependenciesMeta": {
    "playwright-core": {
      "optional": false
    }
  },
  "dependencies": {
    "async-lock": "1.4.1",
    "axios": "1.15.2",
    "chokidar": "^5.0.0",
    "chrome-remote-interface": "0.34.0",
    "compare-versions": "6.1.1",
    "debug": "4.4.3",
    "dedent": "1.7.2",
    "extract-zip": "2.0.1",
    "fast-glob": "3.3.3",
    "once": "1.4.0",
    "proper-lockfile": "4.1.2"
  },
  "devDependencies": {
    "@cheshire-caat/prettier-config": "^1.0.0",
    "@eslint/js": "^10.0.1",
    "jiti": "^2.7.0",
    "mocha": "^11.3.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.3",
    "@types/debug": "^4.1.12",
    "@types/node": "^25.7.0",
    "@types/once": "^1.4.4",
    "@types/proper-lockfile": "^4.1.4",
    "dotenv": "^17.4.1",
    "@types/async-lock": "^1.4.2",
    "@types/chrome-remote-interface": "^0.33.0",
    "napi-macros": "^2.2.2"
  },
  "prettier": "@cheshire-caat/prettier-config"
}